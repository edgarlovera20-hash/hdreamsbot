APP_ENV=production
API_PORT=80

# Base de datos
DB_HOST=mysql
DB_NAME=hdreams
DB_USER=hdreams
DB_PASS=hdreams_pass
DB_ROOT_PASS=root_pass_seguro

# OpenAI
OPENAI_API_KEY=sk-...

# AI Provider (LM Studio recomendado)
AI_PROVIDER=lmstudio
AI_BASE_URL=http://127.0.0.1:1234/v1
AI_API_KEY=lm-studio
AI_MODEL=qwen/qwen3-4b-instruct
AI_TEMPERATURE=0.3
AI_TIMEOUT_MS=20000
REPORT_PYTHON_BIN=python

# Meta
META_VERIFY_TOKEN=token-verificacion-webhook
META_APP_SECRET=app-secret-de-tu-app-meta

# WhatsApp Cloud API
WA_PHONE_ID=
WA_TOKEN=

# Facebook (Messenger / Lead Ads)
FB_PAGE_TOKEN=

# Telegram (opcional)
TELEGRAM_BOT_TOKEN=

# Alertas
RECRUITER_PHONE=521XXXXXXXXXX

# API interna
API_SECRET=cambia-este-secret-largo

# Frontend (CORS)
FRONTEND_URL=https://app.tudominio.com
